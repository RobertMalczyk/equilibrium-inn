# Optional M-H LLM semantic-input seam — copy this file to `.env` and fill in.
# `.env` is gitignored; the key is read from the environment at call time only and
# is NEVER persisted, logged, or written to the trace/session. The seam is OFF
# unless EQUILIBRIUM_INN_LLM_PROVIDER is set. CLI only (the browser cockpit keeps
# it disabled). See README "Optional LLM free-text seam (M-H)".

# Provider: "anthropic" or "openai"
EQUILIBRIUM_INN_LLM_PROVIDER=anthropic

# Your API key for that provider
EQUILIBRIUM_INN_LLM_API_KEY=

# Optional model override (defaults: anthropic -> claude-haiku-4-5-20251001,
# openai -> gpt-4o-mini)
# EQUILIBRIUM_INN_LLM_MODEL=claude-haiku-4-5-20251001
